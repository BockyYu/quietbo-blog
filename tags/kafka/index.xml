&lt;pre&gt;&lt;code&gt; &amp;lt;li class='ez-toc-page-1 ez-toc-heading-level-2'&amp;gt;
 &amp;lt;a class=&amp;quot;ez-toc-link ez-toc-heading-4&amp;quot; href=&amp;quot;https://quietbo.com/2025/07/07/e/#docker-composeyml_%E6%8E%A8%E8%96%A6%E6%96%B9%E5%BC%8F&amp;quot; &amp;gt;docker-compose.yml (推薦方式)&amp;lt;/a&amp;gt;
 &amp;lt;/li&amp;gt;
 &amp;lt;/ul&amp;gt;
&amp;lt;/li&amp;gt;
&lt;/code&gt;&lt;/pre&gt;
 &lt;/ul&gt;&lt;/nav&gt;
